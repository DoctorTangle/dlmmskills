{
  "name": "dlmmskills",
  "version": "1.0.0",
  "private": true,
  "description": "SectorOne DLMM skill and CLI for Base MCP send_calls",
  "type": "module",
  "scripts": {
    "dev": "tsx src/cli/sectorone.ts",
    "sectorone": "tsx src/cli/sectorone.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "bootstrap": "node scripts/bootstrap-sectorone.mjs && node scripts/build-sectorone-sdk.mjs",
