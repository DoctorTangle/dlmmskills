BASE_RPC_URL=https://base-rpc.publicnode.com

# Local signed execution (optional — NOT for Base MCP / Bankr skills)
# NEVER commit real PRIVATE_KEY values.
PRIVATE_KEY=
DRY_RUN=true

# position:execute / position:rebalance — add amounts required
# position:withdraw — remove only (BIN_IDS optional; else discover-lp-bins scan)
# BIN_IDS=8388608,8388609

# Pool / tokens (WETH/USDC example)
POOL_ADDRESS=0x81c74e5b255da07af7697792d4b07532940df870
TOKEN_X=0x4200000000000000000000000000000000000006
TOKEN_Y=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
TOKEN_X_DECIMALS=18
TOKEN_Y_DECIMALS=6
BIN_STEP=10
LB_VERSION=v2

# Add / rebalance amounts
AMOUNT_X=0.000254
AMOUNT_Y=1
DISTRIBUTION=SPOT
BIN_COUNT=50

# Rebalance tuning
REMOVE_BATCH_SIZE=10
SCAN_BINS=60
AMOUNT_SLIPPAGE_BPS=50
PRICE_SLIPPAGE_BPS=50
TTL_SECONDS=1200
